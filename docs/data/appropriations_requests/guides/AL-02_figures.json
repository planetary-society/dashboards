          {
            "field_id": "google_forms:01:entry_1891202125:9ea3092cc182",
            "label": "As an executive summary, please provide a brief description and justification of the project (no more than 250 words):",
            "help_text": "Briefly summarize the project and why it requires funding.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Request for $9,000,000,000 to fund NASA's Science Mission Directorate (SMD) in FY2027\n* Supports peer-reviewed Decadal Survey priorities across Earth Science, Planetary Science, Astrophysics, and Heliophysics\n* Restores agency stability following FY2026 budget volatility to protect thousands of high-skill aerospace jobs\n* Advances fundamental public responsibilities in discovery, national prestige, and practical applications like planetary defense",
            "rationale": "Uses the $9B ask amount and FY2026 context. Justification draws on Decadal Survey priorities and workforce stability arguments from the advocacy talking points.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1847719010:55c9164c887a",
            "label": "Please describe the project's importance to national priorities (no more than 100 words):",
            "help_text": "Explain how this request aligns with national goals.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Strategic Competition: Counters China's rapid expansion in space science to ensure the U.S. continues to set 21st-century exploration norms\n* Economic ROI: Every $1 invested in NASA returns approximately $3 to the economy through industrial demand and innovation\n* Workforce Pipeline: Inspires and sustains the next generation of STEM professionals and entrepreneurs critical to the U.S. technology economy\n* Global Leadership: Maintains the U.S. position as the only nation to reach every major body in the Solar System",
            "rationale": "Directly incorporates advocacy talking points regarding China competition, economic return, and workforce development.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1223248765:ba337de03d5b",
            "label": "Please describe the project's importance to Alabama's 2nd District and/or Alabama at large (no more than 100\nwords):",
            "help_text": "Detail the local impact of the project.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Direct Investment: Over $918,523 in recent NASA Science obligations to institutions within the 2nd District\n* Critical Research: University of South Alabama ($618,691) is studying geomagnetic storm damage to vital ground and space infrastructure\n* Talent Development: Tuskegee University ($299,832) leverages NASA grants to build the local STEM talent pipeline\n* Economic Support: Sustained funding ensures local institutions remain competitive for federal research and development contracts",
            "rationale": "Cites specific spending data for the University of South Alabama and Tuskegee University, including the research focus on geomagnetic storms found in the spending context.",
            "confidence": "high"
          },
