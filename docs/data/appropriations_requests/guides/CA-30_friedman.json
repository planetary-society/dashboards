      {
        "header": "Request Overview",
        "description": "General summary and impact of the request.",
        "fields": [
          {
            "field_id": "microsoft_forms:01:r42eac978a1984c2fb22a69b2b5b650ec:24e59dba3f5f",
            "label": "Clearly state with this request would do in one sentence.",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This request provides $9 billion for NASA's Science Mission Directorate to sustain U.S. leadership in space exploration and support critical missions that drive innovation and economic growth.",
            "rationale": "This concisely states the programmatic funding ask of $9 billion for the Science Mission Directorate as specified in the reference values.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:rabcfa596d31b47c288e33b572bc83a77:3b8b3360869a",
            "label": "How does this request benefit CA-30?",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* NASA Science directly invested $77,413,321 in CA-30 across FY2023-FY2025, supporting a high-tech workforce and industrial base.\n* Supports Honeybee Robotics in Pasadena, which holds a $113.5M contract to develop critical components for the Dragonfly mission to Titan.\n* Funding sustains specialized aerospace jobs at local firms including Maxar Space Robotics, Geooptics, and Glenair, Inc.\n* Every dollar invested in NASA Science returns approximately three dollars to the economy through innovation and demand for cutting-edge R&D.",
            "rationale": "Cites specific spending totals ($77.4M) and key local recipients including Honeybee Robotics, Maxar, Geooptics, and Glenair. Connects local work to the Dragonfly mission and broad economic ROI talking points.",
            "confidence": "high"
          },
          {
