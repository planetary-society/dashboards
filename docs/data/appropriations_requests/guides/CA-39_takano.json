      {
        "header": "Impact of Request",
        "description": null,
        "fields": [
          {
            "field_id": "google_forms:01:entry_1955859321:3e9a88ccde37",
            "label": "Please describe the benefits or impact this request may have on California's 39th District:",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Direct investment of $5,102,913 into the 39th District (FY23-FY25) supporting critical aerospace and planetary research.\n* Supports high-skill research at UC Riverside, including atmospheric characterization of Earth-like exoplanets and modeling of tectonic strain on major Earth faults.\n* Funds complex universe simulations for the Nancy Grace Roman Space Telescope and scientific research for Moon and Mars exploration missions.\n* Strengthens the local STEM talent pipeline by providing inspiration and difficult technical challenges for the district's students and researchers.",
            "rationale": "Cites specific total obligations ($5.1M) and award details for UC Riverside in CA-39, including tectonic modeling and Roman Telescope simulations found in the NASA spending context.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_954594374:87190108de77",
            "label": "Please describe the benefits or impact this request may have on the state of California (if different from above):",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Sustains California's status as the global leader in space science, housing premier NASA centers and leading research universities.\n* Supports a high-tech workforce across the state that develops cutting-edge technology for missions to every major body in the Solar System.\n* Drives statewide economic growth through the aerospace industrial base and academic research grants.\n* Ensures California remains the primary hub for the nation's most ambitious space exploration and Earth observation initiatives.",
            "rationale": "Draws on broader themes of California's leadership in space science and the state's significant aerospace industrial base mentioned in the advocacy context.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1273201758:e8c22b5804ea",
            "label": "Please describe the benefits or impact this request may have nationally (if applicable):",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Maintains U.S. preeminence in space science against rapid expansion and competition from China.\n* Generates approximately $3 of economic return for every $1 invested in NASA programs.\n* Advances national security and scientific priorities, from weather forecasting to planetary defense, as codified in Title 51.\n* Preserves critical technical capabilities and workforce stability within the national aerospace and technology sectors.",
            "rationale": "Uses standard advocacy talking points regarding economic ROI, international competition with China, and Title 51 responsibilities.",
            "confidence": "high"
          }
        ]
      },
