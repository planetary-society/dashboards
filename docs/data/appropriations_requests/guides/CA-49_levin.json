          {
            "field_id": "google_forms:01:entry_839337160:80c61362bb3f",
            "label": "Please describe the connections to CA-49",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Solana Scientific, Inc. in Solana Beach received a $240,364 grant (FY23-25) to research pressure pulse effects on Earth's magnetosphere.\n* Over $350,000 in NASA Science obligations were directed to CA-49 between FY23 and FY25, supporting local research and technical services.\n* Local contract recipients include Flotron ($331,416), Nordson Dage, Inc. ($60,786), and Liquid Instruments Inc ($20,200).\n* These investments sustain a high-skilled STEM workforce in the district that contributes to national space exploration and defense goals.",
            "rationale": "Cites specific grant recipient (Solana Scientific), total district obligations, and top contract recipients (Flotron, Nordson Dage, Liquid Instruments) from the provided CA-49 spending data.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_513996411:f0d970499fd3",
            "label": "Short Title of Request",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "NASA Science Mission Directorate Funding",
            "rationale": "Uses the standard short title for this account as specified in the context.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1118424270:6e9524d32ab2",
            "label": "Description of Request",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* We respectfully request $9 billion for NASA's Science Mission Directorate (SMD) to ensure the stability of the nation's space science workforce.\n* This funding supports the decadal survey priorities that maintain U.S. leadership in space against increasing international competition.\n* Continued investment protects the roughly 3-to-1 economic return on NASA spending that fuels innovation across CA-49 and the nation.\n* This level restores critical mission timelines and research grants after the significant budgetary disruptions and workforce losses of recent years.",
            "rationale": "Utilizes the specific $9 billion ask and incorporates advocacy talking points regarding economic return, decadal surveys, and workforce stability.",
            "confidence": "high"
          },
