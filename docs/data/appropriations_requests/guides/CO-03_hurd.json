      {
        "header": "Request Description",
        "description": "Detailed information about the funding or language request.",
        "fields": [
          {
            "field_id": "pdf:02:request_description:de92a111487a",
            "label": "Description of Program Request or Proposed Bill or Report Language:",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* This programmatic request seeks $9 billion for NASA's Science Mission Directorate (SMD) in the FY2027 CJS Appropriations bill.\n* Funding supports the decadal survey priorities that maintain U.S. leadership in space exploration and scientific discovery.\n* In CO-3, this funding sustains active research at Colorado Mesa University ($300,204) and The Pinhead Institute in Telluride ($299,306).\n* These investments ensure the U.S. remains the global leader in space science, countering rapid expansion in space ambitions by China.",
            "rationale": "Uses the specific $9B ask amount and identifies local grant recipients (CMU and Pinhead Institute) and their cumulative award values from the provided spending data.",
            "confidence": "high"
          },
          {
            "field_id": "pdf:02:request_description:a329097c684b",
            "label": "Program Description / Proposed Language:",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Provide $9 billion for the NASA Science Mission Directorate to support Earth Science, Planetary Science, Astrophysics, Heliophysics, and Biological and Physical Sciences.\n* This funding level restores stability to the scientific workforce following significant disruptions and layoffs in prior fiscal cycles.\n* Sustained investment supports local CO-3 entities like the Aspen Global Change Institute ($949,181 total award) and Colorado Mesa University.\n* Every dollar invested in NASA Science returns approximately three dollars to the U.S. economy through innovation and high-tech demand.",
            "rationale": "Draws on the economic talking points and specific CO-3 grant data for Aspen Global Change Institute and CMU.",
            "confidence": "high"
          }
        ]
      },
