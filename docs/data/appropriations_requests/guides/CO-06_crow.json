        "header": "Project Justification",
        "description": "Narrative explanation for the necessity and impact of the request.",
        "fields": [
          {
            "field_id": "google_forms:01:entry_1734330856:7f6ac4e52f67",
            "label": "Provide an explanation of the problem or issue to be addressed through this request",
            "help_text": "Describe the core challenge this request aims to solve.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Restores stability to NASA's Science Mission Directorate following significant FY2026 budget volatility and workforce disruptions\n* Addresses the $1.75 billion funding gap between current enacted levels ($7.25B) and the $9 billion required to maintain Decadal Survey mission timelines\n* Protects the specialized aerospace workforce and scientific talent pipeline from further erosion due to funding uncertainty\n* Counters rapid expansion of international space science capabilities, specifically China's aggressive lunar and planetary mission schedule",
            "rationale": "The explanation focuses on the funding gap between FY2026 enacted ($7.25B) and the $9B request, while incorporating strategic advocacy points regarding workforce stability and international competition.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_908695868:ed6f2cbf58f1",
            "label": "Provide an explanation of the request's importance to Colorado's Sixth Congressional District",
            "help_text": "Highlight the local impact and benefits to the CO-06 district.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Directly supports high-tech research at The Regents of the University of Colorado in Aurora, including $203,465 for validating satellite water cycle data\n* Sustains local aerospace industry jobs through $701,835 in recent NASA Science obligations across CO-6\n* Benefits district-based contractors including Matheson Tri-Gas ($688,566), LWP Technologies ($290,700), and Boeing Digital Solutions ($42,931)\n* Strengthens the local STEM pipeline by supporting peer-reviewed research and advanced technology development in Aurora and surrounding communities",
            "rationale": "This response cites specific local recipients (CU Aurora, Matheson Tri-Gas, LWP Technologies) and dollar amounts from the provided NASA spending context for CO-6.",
            "confidence": "high"
          }
