          {
            "field_id": "microsoft_forms:01:r575b65d695b5492b8f810e45c39d28fe:356d309715bc",
            "label": "Description of the Programmatic request:",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9,000,000,000 for NASA's Science Mission Directorate (SMD) to support Earth Science, Planetary Science, Astrophysics, Heliophysics, and Biological and Physical Sciences\n* Funding for the implementation of National Academies' Decadal Survey priorities to maintain U.S. global leadership in space exploration\n* Investment in the specialized aerospace workforce and domestic supply chains to provide stability following recent budget volatility",
            "rationale": "Directly reflects the $9 billion programmatic funding ask for NASA SMD as specified in the reference values.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r9bc2310938ff4c188f5fb35caf8ab67e:d3d0b8590daf",
            "label": "Briefly describe the problem/issue this Programmatic request will address.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Counteracts the disruption caused by the FY 2026 budget cuts which led to thousands of layoffs and threatened U.S. aerospace workforce stability\n* Addresses the rapid expansion of China's space program, ensuring the U.S. continues to set the norms for 21st-century exploration\n* Mitigates the high life-cycle costs and mission delays resulting from inconsistent funding of peer-reviewed scientific priorities",
            "rationale": "Draws on the provided advocacy talking points regarding workforce stability, competition with China, and the impact of the FY 2026 funding situation.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r2e464df92b614e87bdb9bdadb53bc724:814f59130612",
            "label": "Briefly describe the goals and/or expected outcome of this Programmatic request.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Secures a predictable funding trajectory for flagship missions like Mars Sample Return and the Habitable Worlds Observatory\n* Advances critical technologies in planetary defense and solar weather forecasting that yield a 3-to-1 economic return on investment\n* Sustains domestic industrial base participation, including local vendors such as Test Equipment Connection Corp. in FL-07",
            "rationale": "Incorporates the economic ROI argument, Decadal Survey priorities, and specific local context for FL-07.",
            "confidence": "high"
          }
        ]
