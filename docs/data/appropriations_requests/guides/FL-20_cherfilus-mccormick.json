          },
          {
            "field_id": "microsoft_forms:01:ref715b4ddac94423b39606bfd9b3e7ba:c9c381949337",
            "label": "Short (must be less than 500 characters) description of program request:",
            "help_text": "Provide a brief summary of the request.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Request $9,000,000,000 for NASA's Science Mission Directorate to restore funding stability and U.S. leadership.\n* Supports over $2.2M in recent local obligations in FL-20, including contracts with Thermo Electron North America LLC.\n* Secures the domestic aerospace workforce and maintains a competitive edge against China's expanding space science ambitions.\n* Funds peer-reviewed Decadal Survey priorities that drive scientific innovation and economic returns.",
            "rationale": "This draft incorporates the $9B ask amount, the total local spending figure ($2.2M), and the specific local contractor (Thermo Electron North America LLC) found in the district spending data. It also leverages strategic talking points regarding competition with China and Decadal Survey priorities.",
            "confidence": "high"
          }
        ]
      },
