          {
            "field_id": "microsoft_forms:01:ref715b4ddac94423b39606bfd9b3e7ba:c9c381949337",
            "label": "Short (must be less than 500 characters) description of program request:",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Request $9 billion for NASA's Science Mission Directorate (SMD) to restore mission stability and advance Decadal Survey priorities.\n* Directly supports innovation in FL-23, including research at Florida Atlantic University to refine computational models for space navigation.\n* Secures U.S. leadership against international competitors like China by funding high-priority missions in planetary science and astrophysics.\n* Stimulates local economic activity; NASA science investments in the district totaled over $860,000 between FY2023 and FY2025.",
            "rationale": "The description frames the $9 billion request within the context of local impact, specifically citing the $860,257 in recent NASA spending in FL-23 and the active grant at Florida Atlantic University ($477,148) for space navigation modeling. It utilizes advocacy talking points regarding international competition and workforce stability.",
            "confidence": "high"
          }
        ]
