          {
            "field_id": "google_forms:01:entry_136553375:2606580dc162",
            "label": "Please provide a brief description of and justification for your request.",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This request provides $9 billion for NASA's Science Mission Directorate to restore U.S. leadership in space exploration and ensure workforce stability following recent budgetary disruptions. Every dollar invested in NASA returns roughly three dollars to the economy, supporting local innovation at Georgia-4 companies like Classone Equipment and Intercax, LLC. Sustained funding is critical to meet the challenge of international competition and to fulfill the scientific priorities established by the National Academies.",
            "rationale": "Combines the $9B funding ask with advocacy talking points regarding economic return, international competition, and local district impact mentioning GA-4 contractors like Classone Equipment and Intercax.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1173931453:b931f5483199",
            "label": "Please provide any additional information you think will assist in our evaluation of your request, including impact to communities in Georgia's 4th Congressional District, the state of Georgia or national implications.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Direct economic impact in GA-04 with over $267,500 in recent NASA Science obligations supporting local high-tech firms including Classone Equipment Inc, Intercax, LLC, and Raptor Photonics, Inc.\n* NASA Science investment yields a 3-to-1 economic return, driving demand for Georgia's specialized aerospace and technical innovation workforce.\n* Funding at $9 billion secures U.S. strategic leadership in space science, countering China's rapid expansion and ensuring the U.S. sets the norms for 21st-century exploration.\n* Sustained investment protects thousands of technical jobs and maintains the talent pipeline essential for American competitiveness and national security.",
            "rationale": "The response highlights specific GA-04 recipients (Classone Equipment, Intercax, LLC) and the total local spending amount ($267,537.60) from the provided NASA context. It also incorporates advocacy talking points regarding economic ROI, the 21st-century space race with China, and workforce stability.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_765739080:8f2e367fb9dd",
            "label": "Is a Congressmember leading a letter on this issue? If yes, please note who and include the appropriate contact information.",
            "help_text": null,
