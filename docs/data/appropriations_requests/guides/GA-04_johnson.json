            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Yes, Reps. Don Bacon (R-NE) and Judy Chu (D-CA) are leading a multi-member support letter in the House.",
            "rationale": "Reference values confirm an existing House letter led by Reps. Bacon and Chu.",
            "confidence": "high"
