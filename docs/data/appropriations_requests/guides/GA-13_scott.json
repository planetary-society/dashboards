      {
        "header": "Section Three: Justifications",
        "description": "Narrative justifications and descriptions of the impact of the request.",
        "fields": [
          {
            "field_id": "pdf:04:section_three_justifications:3f58c602c802",
            "label": "Description of programmatic or language request (500 words or less):",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9,000,000,000 for NASA's Science Mission Directorate (SMD) to support Earth Science, Planetary Science, Astrophysics, Heliophysics, and Biological and Physical Sciences.\n* This funding level represents a necessary restoration and increase over the FY2026 enacted level of $7.25 billion to maintain mission schedules and scientific integrity.\n* The request supports the execution of National Academies' Decadal Surveys, ensuring the U.S. continues to lead in breakthrough space exploration and discovery.",
            "rationale": "Values are taken directly from the 'Funding Ask' and 'SMD Topline Funding History' in the reference data.",
            "confidence": "high"
          },
          {
            "field_id": "pdf:01:section_three_justifications:92acc12010a0",
            "label": "How this programmatic or language request will help your organization, community, Georgia, and/or the nation (150 words or less):",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Sustains U.S. leadership in the global space race, specifically countering China's rapid expansion in lunar and planetary exploration.\n* Strengthens the national and regional STEM pipeline, providing the inspiration and technical challenges required to train Georgia's future aerospace workforce.\n* Delivers critical national data for weather forecasting, climate resilience, and planetary defense, protecting American lives and infrastructure.",
            "rationale": "Since there is no direct NASA Science spending in GA-13, the justification focuses on national leadership, workforce development, and broader societal benefits as outlined in the advocacy points.",
            "confidence": "high"
          },
          {
            "field_id": "pdf:01:section_three_justifications:16b3917a4eff",
            "label": "Why would federal resources used to carry out this programmatic/language request be an appropriate use of taxpayer resources (150 words or less):",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
