          },
          {
            "field_id": "microsoft_forms:01:r088699d0a0af417bab9199dd695717e9:4e8cbaecd22c",
            "label": "Additional Comments",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* IL-1 institutions, led by the University of Chicago, received over $30.5M in NASA Science obligations (FY2023-FY2025), supporting 54 research grants.\n* Funding supports critical local capabilities like the EUSO-SPB2 cosmic ray observatory and advanced spectrometer development, ensuring IL-1 remains a hub for space exploration technology.\n* Sustained investment at $9B is vital to counter rapidly expanding space science programs in China and maintain the U.S. lead in setting 21st-century exploration norms.\n* NASA Science provides a 3-to-1 economic return and secures the STEM talent pipeline that IL-1's innovation economy depends on for growth.",
            "rationale": "The draft value highlights the $30.5M in recent NASA Science obligations to IL-1, specifically noting the University of Chicago's leadership in 54 grants and local technical contributions like the EUSO-SPB2 observatory. It connects these local facts to national strategic priorities including economic ROI and international competition with China.",
            "confidence": "high"
          }
