          {
            "field_id": "microsoft_forms:01:r93c60d9000ca4263b75a8b079ae4de25:212dbe50e3c5",
            "label": "If you want Congressman Jackson to support a specific funding amount, what amount of funding do you request?",
            "help_text": "Enter the specific dollar amount requested for the program.",
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "$9,000,000,000",
            "rationale": "This matches the $9 billion funding ask specified for NASA's Science Mission Directorate in the reference values.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r0020c6097440444cb4d474b9adf1ac62:25dee86facd1",
            "label": "Please describe the program you want Congressman Jackson to support in 500 words or fewer.",
            "help_text": null,
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "The NASA Science Mission Directorate (SMD) conducts decadal-priority research that ensures U.S. leadership in space. This investment supports over $30 million in recent NASA spending in IL-01, primarily through the University of Chicago, which leads critical missions like the EUSO-SPB2 balloon observatory and advanced sample analysis. National funding at $9 billion is essential to restore workforce stability after FY2026 disruptions and maintain our competitive edge against rapidly expanding international space programs.",
            "rationale": "Combines the $9 billion programmatic request with specific local economic data ($30.5M in IL-1) and University of Chicago grant details provided in the spending context.",
            "confidence": "high"
          }
        ]
      },
