      {
        "header": "Narrative and Impact",
        "description": "Justification and local impact of the request.",
        "fields": [
          {
            "field_id": "microsoft_forms:01:r11b059ac4cf24a9dbc7b5899f072c3c9:fc88dda41d9f",
            "label": "Description of Programmatic Request",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9 billion for NASA's Science Mission Directorate to support Earth Science, Planetary Science, Astrophysics, and Heliophysics.\n* Funding advances National Academies' Decadal Survey priorities and sustains U.S. leadership in the face of rising international competition.\n* Restores stability to the aerospace workforce and contractor base, ensuring the U.S. continues to set norms for 21st-century space exploration.",
            "rationale": "Based on the $9 billion programmatic ask for SMD and strategic talking points regarding Decadal Survey priorities and global leadership.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r845777ed08ec470499b9a09ffe7e7c1a:d4bd014088ec",
            "label": "Is another Member of Congress already leading a letter in support of this request? If so, please list which office and the point of contact.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Representatives Don Bacon (R-NE) and Judy Chu (D-CA) are leading a bipartisan House letter in support of this funding request.",
            "rationale": "Reference values explicitly state that Reps. Bacon and Chu are leading a House letter.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:rbfd31331de12492686b84c0041a99fd8:50c55ecb0ff1",
            "label": "Impact on MN-03",
            "help_text": "Describe the specific benefits of this request to Minnesota's 3rd Congressional District.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* NASA Science awarded over $2.5 million to MN-03 businesses in recent years, directly supporting the local innovation economy and high-tech jobs.\n* Ideal System Solutions in Hopkins and Maple Grove provided nearly $2 million in specialized software and testing tools for Goddard Space Flight Center.\n* Funding supports advanced manufacturing and technical services at local firms including Proto Labs, Physical Electronics USA, and Stratasys.",
            "rationale": "Uses specific district spending data ($2,571,307.81 total) and names top local recipients like Ideal System Solutions and Proto Labs.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r378ad6d64fcd4034ad92b4c42b746d52:f7e9004ea1b2",
            "label": "Please provide any other information you believe would be helpful in reviewing this request.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Every dollar invested in NASA Science returns roughly three dollars to the U.S. economy while strengthening the domestic STEM talent pipeline.\n* Space science is a fundamental public responsibility codified in Title 51 that maintains U.S. economic and security advantages.\n* This investment is highly popular and non-partisan, consistently cited as a top priority in public polling.",
            "rationale": "Drawn from advocacy talking points regarding economic ROI, workforce development, and public support.",
            "confidence": "high"
          }
