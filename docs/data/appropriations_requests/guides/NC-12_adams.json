            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This is a broad request being submitted to multiple offices to demonstrate widespread, bipartisan support for NASA's Science Mission Directorate and its critical role in U.S. space leadership.",
            "rationale": "Provides a concise explanation for the multi-office nature of the request, focusing on bipartisan support.",
