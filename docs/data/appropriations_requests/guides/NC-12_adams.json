          },
          {
            "field_id": "microsoft_forms:01:r5e5cef428ce64812b3ea2fd2a2b95c68:80073e965af1",
            "label": "Request details",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Provide $9 billion for NASA Science. This funding supports essential research at institutions like UNC Charlotte, which has received nearly $600,000 in recent NASA grants for projects ranging from environmental justice to microbial science. This investment ensures America's competitive edge in the space race with China and maintains our technical workforce.",
            "rationale": "Incorporates the $9B ask, specific local impacts for UNC Charlotte, and strategic themes of international competition and workforce stability.",
            "confidence": "high"
          },
