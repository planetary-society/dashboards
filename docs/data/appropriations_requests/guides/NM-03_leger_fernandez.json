      {
        "header": "Justification and Impact",
        "description": null,
        "fields": [
          {
            "field_id": "microsoft_forms:01:rb04c849998d94fdaaf9fe1387046c561:06271396dcdc",
            "label": "Description of the Program Request or Proposed Language",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This programmatic request seeks $9 billion for NASA's Science Mission Directorate (SMD). Funding supports Earth science, planetary science, astrophysics, and heliophysics to ensure U.S. leadership in space, maintain the specialized workforce, and follow the scientific priorities of the National Academies' Decadal Surveys.",
            "rationale": "Synthesizes the short description with advocacy talking points regarding leadership, workforce, and decadal surveys.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:rf5d91ef4825d4f83ac78a316572589dc:af0a1ca00b1c",
            "label": "Impact on New Mexico's 3rd Congressional District \n",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "NASA Science has invested $2,580,764.71 in annual obligations in NM-03 across FY23-FY25. This includes $6,492,406.81 in total grants to Nmc, Inc. for solar wind and radiation belt research, and $622,713.00 to Geolabe LLC to automate earthquake fault detection using satellite data, supporting high-tech jobs in Los Alamos and Santa Fe.",
            "rationale": "Uses specific district data including total spending and top recipients (NMC, Inc. and Geolabe LLC) to demonstrate local economic and scientific impact.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r912859b836344b7a9545f4fc05c76b19:c71e24d36167",
            "label": "Member of Congress Leading the Request (if any)",
            "help_text": null,
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Reps. Don Bacon and Judy Chu",
            "rationale": "Reference values identify these members as the leads for the existing House letter.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:rdd8c0273330d4ddea599ba99f0da3299:2751be584f8a",
            "label": "Your Priority Level (if submitting multiple requests)",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": null,
            "rationale": "Priority level is a user-specific determination.",
            "confidence": "low"
          },
          {
            "field_id": "microsoft_forms:01:rd00342991c7447e6badce0b41afead96:01a7f78cfc33",
            "label": "Additional Comments",
            "help_text": null,
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Sustained funding is critical for workforce stability after the disruptions of FY2026. This investment supports the talent pipeline and ensures the U.S. remains the partner of choice for international space collaboration while competing effectively with expanding international programs.",
            "rationale": "Incorporates advocacy talking points regarding workforce stability and international competition.",
            "confidence": "high"
          }
        ]
