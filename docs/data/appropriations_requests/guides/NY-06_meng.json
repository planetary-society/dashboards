          {
            "field_id": "microsoft_forms:01:r77e4f939f2cd46f78b8649cb9ddcef11:8994a7dd7dca",
            "label": "Short (must be less than 500 characters) description of program request:",
            "help_text": "Provide a brief narrative of what the funding will support.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9B for NASA SMD to restore funding and maintain global leadership against rising international competition.\n* Supports NY-6 entities like Kepco, Inc. and the Research Foundation of CUNY, which received over $425,000 in NASA Science funding since FY2023.\n* Every $1 invested in NASA returns $3 to the economy, fueling local innovation and the STEM talent pipeline.\n* Advances nonpartisan Decadal Survey priorities for solar system exploration and planetary defense.",
            "rationale": "This draft supports the $9B topline ask for NASA Science while highlighting local economic and scientific impacts in NY-6, specifically citing the $425,974 in district spending across Kepco, Inc. and the Research Foundation of CUNY. It incorporates key advocacy talking points regarding international competition and economic ROI.",
            "confidence": "high"
          },
