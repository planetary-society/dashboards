      {
        "header": "General Information",
        "description": "Information about the relation of the request to the district and descriptions of the problem/project.",
        "fields": [
          {
            "field_id": "congressional_site:01:edit-how-does-this-request-benefit-district:85b6245a0d87",
            "label": "Limit is 2000 characters.",
            "help_text": "Does this request have any specific relation to the State of South Carolina's 1st Congressional District? If so, please describe",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Directly supports high-tech small business activity in SC-1, such as Seres Engineering & Services LLC, which received $117,106 for Moon, Mars, and planetary defense research.\n* Strengthens the local aerospace workforce and innovation economy by funding specialized engineering and scientific services.\n* Invests in the STEM talent pipeline in South Carolina's 1st District, ensuring the region remains competitive in the global space economy.",
            "rationale": "Directly references the specific local grant recipient and amount found in the NASA spending context for SC-1.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-problem:2a6867115718",
            "label": "Limit is 2000 characters.",
            "help_text": "Describe the problem or issue to be addressed through this request:",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Sustained budget volatility has caused the loss of thousands of skilled aerospace contractors and pressured over 4,000 civil servants to exit the agency.\n* Rapidly expanding space science ambitions from China, including Mars rovers and lunar sample returns, challenge U.S. leadership and the ability to set 21st-century exploration norms.\n* Funding shortfalls threaten the execution of nonpartisan Decadal Survey priorities, risking the loss of decades of technological investment.",
            "rationale": "Draws on the provided advocacy talking points regarding workforce stability and international competition.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-project:cfd3b90f29b7",
            "label": "Limit is 2000 characters.",
            "help_text": "Describe the program, what it will do, and why it is necessary:",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Requests $9 billion for the NASA Science Mission Directorate to fund a comprehensive portfolio of space exploration and scientific discovery missions.\n* Implements peer-reviewed National Academies Decadal Survey priorities to answer fundamental questions about the Solar System and the universe.\n* Delivers an estimated 3:1 return on investment to the U.S. economy while advancing critical technologies for planetary defense and aerospace competitiveness.",
            "rationale": "Uses the $9 billion ask amount and core advocacy points about SMD's mission and economic impact.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-please-include-all-such-partners:a60ad4c4d2ad",
            "label": "Limit is 2000 characters.",
            "help_text": "Please include all such partners with whom you will be working or from whom you have requested additional funding for your program or project:",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Supported by the American Astronomical Society (AAS) and the American Geophysical Union (AGU).\n* Bipartisan coalition in the House of Representatives led by Reps. Don Bacon (R-NE) and Judy Chu (D-CA).\n* Collaborates with a nationwide network of academic institutions and industrial partners involved in NASA's scientific roadmaps.",
            "rationale": "Identifies the specific allied organizations and House leadership mentioned in the reference values.",
            "confidence": "high"
