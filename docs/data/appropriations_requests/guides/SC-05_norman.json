          {
            "field_id": "congressional_site:01:description:41bd1ae835d7",
            "label": "Description:*",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9 billion programmatic funding for NASA Science Mission Directorate (SMD)\n* $1.75 billion increase over FY2026 enacted levels to restore mission stability and progress\n* Supports execution of non-partisan National Academies Decadal Survey priorities across all divisions\n* Ensures continued U.S. dominance in space exploration, astrophysics, and planetary defense",
            "rationale": "Uses the pre-computed funding ask of $9B, the calculated net increase over FY26 enacted, and core SMD advocacy points regarding Decadal Surveys and U.S. leadership.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:impact:8f654c40d590",
            "label": "Specific Positive Impact for South Carolina's Fifth District:*",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Direct economic activity in SC-05 via contractors Newark Corporation ($40,091 in FY25) and 3d Systems, Inc. ($15,800 in FY23)\n* Sustains regional aerospace and innovation workforce through specialized technical procurement\n* Contributes to the national $3 economic return for every $1 invested in NASA programs\n* Bolsters the local STEM talent pipeline by providing demand for cutting-edge R&D and advanced manufacturing",
            "rationale": "Cites specific spending data for SC-05, including exact dollar amounts and names for Newark Corporation and 3d Systems, Inc., combined with the 3:1 ROI advocacy point.",
            "confidence": "high"
          },
          {
