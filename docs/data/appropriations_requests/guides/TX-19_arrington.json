          {
            "field_id": "microsoft_forms:01:r1b4208f73ce641f9931fb87c24d73e63:fe816fa6f143",
            "label": "Subcommittee of Jurisdiction",
            "help_text": null,
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Commerce, Justice, Science, and Related Agencies",
            "rationale": "NASA funding falls under the CJS subcommittee.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r67b3ac9dca0e4503a26f4fad1f65fc30:a48e3e8b989b",
            "label": "Description of Request and Importance of Program (Please limit response to 400 words)",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Request $9 billion for NASA's Science Mission Directorate (SMD) to maintain U.S. preeminence in space science and restore funding levels necessary for mission stability.\n* SMD executes the scientific community's peer-reviewed Decadal Survey priorities, advancing critical research in planetary defense, climate science, and solar system exploration.\n* Sustained investment is vital for national competitiveness as China aggressively expands its Mars and lunar sample return programs to set 21st-century exploration norms.\n* NASA Science delivers a unique return on investment by solving difficult technical challenges that catalyze American innovation and provide a steady demand for high-skilled R&D.",
            "rationale": "This response highlights the $9B ask and frames it within the context of U.S. leadership, Decadal Survey priorities, and international competition as suggested in the Advocacy Talking Points.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:rb5efd78f723f4ac5ae9cd65acd542e7e:578b6121fa54",
            "label": "How does this request directly impact TX-19?\u0000Please describe the return-on-investment for the American taxpayer, and describe results if funding is NOT received.",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* NASA Science directly supports the Texas Tech University System with over $3.3 million in recent grants for research on rainfall patterns, compact objects, and Moon/Mars exploration strategy.\n* The program provides $885,701 in grant funding to Hardin-Simmons University, strengthening the regional STEM pipeline and providing advanced research opportunities for Texas students.\n* Every dollar invested in NASA Science returns roughly $3 to the economy, fueling a specialized aerospace workforce that would be at risk if funding remains stagnant.\n* Without this funding, the U.S. risks ceding scientific leadership to international competitors and disrupting decades of hard-won technical capability in the Lubbock region.",
            "rationale": "This leverages the specific spending data for TX-19, citing Texas Tech University and Hardin-Simmons University, along with the 3:1 ROI talking point.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r202513d169b3492a81d80e33613ecfb6:e63e73899c36",
            "label": "Clearly state what this programmatic/language request would do in one sentence",
            "help_text": null,
            "field_type": "text",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This request would provide $9 billion for NASA's Science Mission Directorate to ensure U.S. leadership in space exploration and support critical research at institutions like Texas Tech University.",
            "rationale": "Combines the topline funding ask with local relevance to Texas Tech University System, which is a major recipient in TX-19.",
            "confidence": "high"
          }
        ]
      },
