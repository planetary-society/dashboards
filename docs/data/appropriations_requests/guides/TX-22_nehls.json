      {
        "header": "General Information",
        "description": "Narrative descriptions of the request's purpose and impact.",
        "fields": [
          {
            "field_id": "congressional_site:01:edit-how-does-this-request-benefit-district:85b6245a0d87",
            "label": "Limit is 2000 characters.",
            "help_text": "Describe why this is a good use of taxpayer funds and how it benefits the district.",
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Direct investment in the TX-22 industrial base through $476,589.12 in recent NASA Science contract obligations.\n* Supports high-tech manufacturing at Schlumberger Technology Corp in Sugar Land, which holds a $2,855,464.73 total award for specialized neutron generators.\n* Engagement of local engineering firms like Kalsi Engineering and Texas Flange & Fitting Supply in the space exploration supply chain.\n* Strengthens the regional STEM workforce and aerospace talent pipeline critical to Texas's economic competitiveness.",
            "rationale": "Cites specific local spending data and contract recipients from the NASA spending context, including the Schlumberger award in Sugar Land.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-problem:2a6867115718",
            "label": "Limit is 2000 characters.",
            "help_text": "Describe the problem or issue to be addressed through this request.",
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Sustained, bipartisan investment is required to maintain U.S. leadership in space science against rapid expansion by international competitors like China.\n* Funding volatility threatens the stability of the domestic aerospace workforce and the specialized contractor base in districts like TX-22.\n* Budget uncertainty leads to costly mission delays and inefficiencies that waste taxpayer resources and risk the loss of critical technical capabilities.\n* Current funding levels jeopardize the execution of National Academies Decadal Survey priorities, which are essential for long-term scientific and strategic superiority.",
            "rationale": "Draws on advocacy talking points regarding international competition, workforce stability, and the disruption caused by prior year budget cuts.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-project:cfd3b90f29b7",
            "label": "Limit is 2000 characters.",
            "help_text": "Describe the project or program, what it will do and why it is necessary.",
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Requests $9 billion for NASA's Science Mission Directorate to fund exploration of the solar system, planetary defense, and Earth science.\n* Enables high-priority missions that advance scientific discovery, improve weather forecasting, and maintain national prestige.\n* Leverages a 3-to-1 economic return on investment by providing a steady demand for cutting-edge R&D and specialized technical hardware.\n* Supports the fundamental public responsibility to lead in space science as codified in Title 51 of the U.S. Code.",
            "rationale": "Utilizes the specific ask amount of $9 billion and incorporates the economic return and Title 51 advocacy talking points.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-please-include-all-such-partners:a60ad4c4d2ad",
            "label": "Limit is 2000 characters.",
            "help_text": "Please include all such partners with whom you will be working or from whom you have requested additional funding.",
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* American Astronomical Society (AAS)\n* American Geophysical Union (AGU)",
            "rationale": "Lists the allied organizations provided in the congressional support reference values.",
            "confidence": "high"
          }
        ]
      },
