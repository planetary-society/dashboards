          {
            "field_id": "google_forms:01:entry_61043469:125d8e4bec63",
            "label": "Clearly state what the request language and or funding would do",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This funding supports NASA's Science Mission Directorate, which invested over $227 million in TX-31 across FY23-FY25. It specifically enables commercial lunar payload delivery services through local partners like Firefly Aerospace in Cedar Park, ensuring U.S. leadership in space science and economic competitiveness.",
            "rationale": "Uses local spending data ($227M in TX-31) and specifically references Firefly Aerospace in Cedar Park to demonstrate local economic impact and workforce relevance to Representative Carter.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_1697314630:9131906338d3",
            "label": "Please include any additional information here.",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Strategic investment to maintain U.S. leadership against rapid Chinese expansion in lunar and planetary science\n* Economic multiplier effect returning approximately $3 to the economy for every $1 invested\n* Supports a highly specialized national workforce of civil servants and private contractors following FY 2026 funding disruptions\n* Adherence to peer-reviewed National Academies Decadal Survey priorities for non-partisan scientific advancement",
            "rationale": "Incorporates core advocacy talking points regarding economic impact, international competition, and workforce stability.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_814632815:c34afeef9f49",
            "label": "How does request directly impact TX-31?",
            "help_text": "Explain the specific benefits to the 31st Congressional District of Texas.",
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Over $227M in NASA Science obligations within TX-31 between FY2023 and FY2025\n* Direct support for Cedar Park-based Firefly Aerospace Inc, which holds over $334M in total NASA contract awards\n* Sustains high-tech manufacturing and engineering jobs focused on commercial lunar payload delivery services\n* Drives local innovation in low-cost small satellite launch capabilities and deep space hardware",
            "rationale": "Uses specific spending data for TX-31, highlighting Firefly Aerospace's $334M in contract awards and the $227M in obligations over the last three fiscal years.",
            "confidence": "high"
          },
          {
