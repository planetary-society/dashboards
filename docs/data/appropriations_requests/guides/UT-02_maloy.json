          {
            "field_id": "microsoft_forms:01:r8eae07898f534ffe81b4796b40087d98:df765cdc1e71",
            "label": "What problem or issue will your request address?",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Restores stability to the U.S. aerospace workforce following the disruptive FY 2026 budget cycle which threatened thousands of high-skill technical positions.\n* Counteracts the rapid expansion of China's space science program to ensure the United States continues to set the international norms for lunar and planetary exploration.\n* Provides the necessary $9 billion for the Science Mission Directorate to meet National Academies' decadal priorities that maintain American leadership in space.\n* Addresses the risk of losing unique, hard-won technical capabilities at NASA centers and within the industrial base due to inconsistent funding levels.",
            "rationale": "Uses Advocacy Talking Points regarding competition with China, workforce stability, and the restoration of funding following the FY 2026 cuts.",
            "confidence": "high"
          },
