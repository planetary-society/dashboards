          {
            "field_id": "google_forms:01:entry_2073035996:68a888f78df9",
            "label": "Why is the request a good use of taxpayer dollars? Please state your justification for this request.",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* NASA Science provides a 3-to-1 economic return on investment, fueling a national network of high-tech suppliers and a skilled workforce.\n* Sustained funding is a strategic necessity to maintain American leadership as international competitors, notably China, rapidly expand their space science capabilities.\n* NASA programs advance peer-reviewed scientific priorities that provide essential data for weather forecasting, resource management, and planetary defense.\n* Protects the domestic aerospace talent pipeline from further erosion following significant budget instability and layoffs in previous fiscal years.",
            "rationale": "Draws on economic ROI, international competition, and workforce stability arguments from the advocacy talking points.",
            "confidence": "high"
          },
          {
            "field_id": "google_forms:01:entry_850570264:878399cb706d",
            "label": "Please explain the request's importance to Washington's Third Congressional District. ",
            "help_text": null,
            "field_type": "textarea",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Supports local high-tech manufacturing including Nlight Inc in Camas, which holds a $1.49M NASA contract for specialized technology.\n* Directly benefits district employers Tfi-Telemark, Inc. ($86,050) and Light Integration Technologies LLC for mission-critical components.\n* Sustains public engagement and STEM communication via the Association of Science Communicators in Vancouver.\n* Recent NASA Science activity in WA-03 represents over $138,000 in direct obligations to district businesses and institutions.",
            "rationale": "Cites specific local recipients (Nlight, Tfi-Telemark, ASC) and dollar amounts from the WA-3 spending data.",
            "confidence": "high"
          }
