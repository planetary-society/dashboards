            "is_prior_year_field": false,
            "draft_value": "NASA Science Mission Directorate Funding",
            "rationale": "A concise title that clearly identifies the program for which funding is being requested.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r44b5d6e761f544179dad24cb4bd7d673:814833823f37",
            "label": "Request Description",
            "help_text": null,
            "field_type": "text",
            "required": true,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "This request provides $9,000,000,000 for NASA's Science Mission Directorate to sustain U.S. leadership in space, counter international competition, and support the aerospace workforce. In WA-9, this funding supports critical partners like Blue Origin in Kent, which received over $18 million to enable commercial delivery of science payloads to the Moon.",
            "rationale": "Combines the specific $9 billion ask with local economic context (Blue Origin in Kent) and strategic arguments regarding global competition and workforce stability.",
            "confidence": "high"
          },
          {
            "field_id": "microsoft_forms:01:r022d9d43a72742c582bef7623141d4b5:4d4d45db7d17",
            "label": "Request Type",
            "help_text": null,
            "field_type": "radio",
            "required": true,
            "options": [
              "Programmatic",
              "Bill Language",
              "Report Language"
            ],
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "Programmatic",
            "rationale": "The request seeks a specific funding level ($9 billion) for an existing agency account (NASA Science), which is a programmatic request.",
            "confidence": "high"
          }
        ]
      }
