          {
            "field_id": "congressional_site:01:edit-how-does-this-request-benefit-district:86672e24625a",
            "label": "Why is this funding a good use of taxpayer funds?",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* Every $1 invested in NASA returns approximately $3 to the U.S. economy, turbocharging the industrial and innovation workforce.\n* Strengthens the national STEM talent pipeline by providing high-tech challenges that private entities cannot replicate.\n* Ensures the U.S. continues to set the norms for 21st-century exploration in the face of rapid competition from China.\n* Space science is a fundamental public responsibility under Title 51 that delivers practical applications in weather forecasting and planetary defense.",
            "rationale": "Uses advocacy talking points regarding economic ROI, workforce development, and strategic competition to justify spending in a district with $0 direct NASA SMD funding.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-problem:d22647227d73",
            "label": "Please describe the problem this request addresses",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* China's rapid expansion in space science, including Mars rovers and lunar sample returns, threatens decades of U.S. leadership.\n* Significant funding volatility in FY 2026 led to the loss of thousands of skilled contractor positions and thousands of civil servants.\n* Current funding levels below $9 billion risk the cancellation or delay of peer-reviewed Decadal Survey mission priorities.\n* Inconsistent investment jeopardizes hard-won technical capabilities and national prestige that are not easily recovered once lost.",
            "rationale": "Draws on the Advocacy Context regarding competition with China and the specific workforce disruptions cited in the talking points.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-describe-the-project:6511270d7a16",
            "label": "Description of Your Request",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* $9 billion programmatic funding request for NASA's Science Mission Directorate (SMD) for Fiscal Year 2027.\n* Supports the execution of National Academies' Decadal Surveys across Earth Science, Planetary Science, Astrophysics, and Heliophysics.\n* Funds a portfolio of missions that provide a nonpartisan, rigorous basis for strategic national investment decisions.\n* Advances U.S. leadership in the new space race through sustained, bipartisan commitment to scientific discovery.",
            "rationale": "Cites the specific $9B ask amount and the program status (SMD) from the asks_config and reference values.",
            "confidence": "high"
          },
          {
            "field_id": "congressional_site:01:edit-please-include-all-such-partners:6cab42535e6a",
            "label": "Partners Working on the Project",
            "help_text": null,
            "field_type": "textarea",
            "required": false,
            "options": null,
            "is_constituent_info": false,
            "is_prior_year_field": false,
            "draft_value": "* American Astronomical Society (AAS) and American Geophysical Union (AGU).\n* Bipartisan House support led by Representatives Don Bacon (R-NE) and Judy Chu (D-CA).\n* Industrial and academic partners across 75% of U.S. congressional districts.\n* International partners on various NASA SMD missions that reinforce U.S.-led norms in space.",
            "rationale": "References specific allied organizations and the bipartisan letter leads provided in the reference context.",
            "confidence": "high"
          }
